generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  active    Boolean   @default(true)
  processes Process[]
  trainees  Trainee[]
  createdAt DateTime  @default(now())
}

model Process {
  id               Int              @id @default(autoincrement())
  name             String
  departmentId     Int
  department       Department       @relation(fields: [departmentId], references: [id])
  active           Boolean          @default(true)
  recommendedTrainingHours Decimal? @db.Decimal(6, 2)
  traineeProcesses TraineeProcess[]
  createdAt        DateTime         @default(now())

  @@unique([departmentId, name])
}

model Trainee {
  id               Int              @id @default(autoincrement())
  name             String
  departmentId     Int
  department       Department       @relation(fields: [departmentId], references: [id])
  teamLeader       String?
  shiftLeader      String?
  trainingAssessor String?
  shift            String?
  startDate        DateTime?
  archived         Boolean          @default(false)
  traineeProcesses TraineeProcess[]
  timelineEvents   TimelineEvent[]
  processCheckIns  ProcessCheckIn[]
  createdAt        DateTime         @default(now())

  @@unique([name, departmentId, shift])
  @@index([departmentId, name])
}

model TrainingAssessor {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model TeamLeader {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model TrainingBuddy {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model Person {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  roles     PersonRole[]
}

model Role {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  people    PersonRole[]
  createdAt DateTime     @default(now())
}

model PersonRole {
  personId Int
  roleId   Int
  person   Person @relation(fields: [personId], references: [id])
  role     Role   @relation(fields: [roleId], references: [id])

  @@id([personId, roleId])
}

model TraineeProcess {
  id                         Int                 @id @default(autoincrement())
  traineeId                  Int
  processId                  Int
  trainee                    Trainee             @relation(fields: [traineeId], references: [id])
  process                    Process             @relation(fields: [processId], references: [id])
  stage                      String              @default("Requested")
  status                     String              @default("Active")
  department                 String
  trainingBuddy              String?
  trainingStartDate          DateTime?
  lastCheckInDate            DateTime?
  buddyFeedbackScore         Int?
  assessorObservationScore   Int?
  timeSpentInShifts          Int?
  readinessScore             Int?
  recommendedTrainingHours   Decimal?            @db.Decimal(6, 2)
  assignmentStatus           String              @default("ACTIVE")
  removedAt                  DateTime?
  removalNote                String?
  removedBy                  String?
  readyForPreAssessment      Boolean             @default(false)
  scheduledPreAssessmentDate DateTime?
  preAssessmentDate          DateTime?
  preAssessmentOutcome       String?
  scheduledAssessmentDate    DateTime?
  assessmentDate             DateTime?
  assessmentOutcome          String?
  competencySignOffDate      DateTime?
  assignedAssessor           String?
  nextAction                 String?
  followUpFlag               String?
  requestedBy                String?
  riskAssessmentComplete     Boolean             @default(false)
  sopComplete                Boolean             @default(false)
  createdAt                  DateTime            @default(now())
  assessmentRecords          AssessmentRecord[]
  weeklyPlannerItems         WeeklyPlannerItem[]
  followUpActions            FollowUpAction[]
  refresherRecord            RefresherRecord?
  timelineEvents             TimelineEvent[]
  checkIns                   ProcessCheckIn[]
  trainingHoursEntries       TrainingHoursEntry[]

  @@index([stage])
  @@index([assessmentOutcome])
  @@index([assignmentStatus])
  @@index([scheduledPreAssessmentDate])
  @@index([scheduledAssessmentDate])
  @@index([department])
}

model TrainingHoursEntry {
  id               Int            @id @default(autoincrement())
  traineeProcessId Int
  traineeProcess   TraineeProcess @relation(fields: [traineeProcessId], references: [id], onDelete: Cascade)
  trainingDate     DateTime
  hours            Decimal        @db.Decimal(5, 2)
  enteredBy        String?
  lastEditedBy     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([traineeProcessId, trainingDate])
  @@index([trainingDate])
  @@index([traineeProcessId, trainingDate])
}

model TimelineEvent {
  id               Int             @id @default(autoincrement())
  traineeId        Int
  traineeProcessId Int?
  trainee          Trainee         @relation(fields: [traineeId], references: [id])
  traineeProcess   TraineeProcess? @relation(fields: [traineeProcessId], references: [id])
  process          String?
  eventType        String
  date             DateTime        @default(now())
  description      String
  user             String
  createdAt        DateTime        @default(now())

  @@index([traineeId, date])
  @@index([traineeProcessId, date])
}

model ProcessCheckIn {
  id               Int            @id @default(autoincrement())
  traineeId        Int
  traineeProcessId Int
  trainee          Trainee        @relation(fields: [traineeId], references: [id])
  traineeProcess   TraineeProcess @relation(fields: [traineeProcessId], references: [id])
  checkInDate      DateTime
  assessor         String
  progressSummary  String
  issuesIdentified String?
  supportRequired  String?
  nextAction       String?
  reviewDate       DateTime?
  createdAt        DateTime       @default(now())

  @@index([traineeId, checkInDate])
  @@index([traineeProcessId, checkInDate])
}

model WeeklyPlannerItem {
  id               Int             @id @default(autoincrement())
  weekCommencing   DateTime
  plannedDate      DateTime
  department       String
  traineeName      String
  process          String
  activityType     String
  owner            String?
  status           String
  actualDate       DateTime?
  deviationReason  String?
  followUpRequired Boolean         @default(false)
  followUpDate     DateTime?
  traineeProcessId Int?
  traineeProcess   TraineeProcess? @relation(fields: [traineeProcessId], references: [id])
  createdAt        DateTime        @default(now())

  @@index([plannedDate])
  @@index([followUpDate])
  @@index([department])
}

model AssessmentRecord {
  id                 Int            @id @default(autoincrement())
  traineeProcessId   Int
  traineeProcess     TraineeProcess @relation(fields: [traineeProcessId], references: [id])
  assessmentType     String
  date               DateTime
  department         String
  traineeName        String
  process            String
  assessor           String
  outcome            String
  strengths          String?
  developmentAreas   String?
  developmentActions String?
  finalOutcome       String?
  followUpRequired   Boolean        @default(false)
  followUpDate       DateTime?
  createdAt          DateTime       @default(now())

  @@index([department, date])
  @@index([traineeName])
}

model RefresherRecord {
  id                 Int            @id @default(autoincrement())
  traineeProcessId   Int            @unique
  traineeProcess     TraineeProcess @relation(fields: [traineeProcessId], references: [id])
  department         String
  traineeName        String
  process            String
  lastCompetencyDate DateTime?
  refresherDueDate   DateTime?
  scheduledRefresherDate DateTime?
  status             String
  scheduleStatus     String?
  daysUntilDue       Int?
  assignedAssessor   String?
  completedDate      DateTime?
  outcome            String?
  createdAt          DateTime       @default(now())

  @@index([refresherDueDate])
  @@index([scheduledRefresherDate])
}

model FollowUpAction {
  id               Int            @id @default(autoincrement())
  traineeProcessId Int
  traineeProcess   TraineeProcess @relation(fields: [traineeProcessId], references: [id])
  title            String
  dueDate          DateTime?
  status           String         @default("Open")
  createdAt        DateTime       @default(now())

  @@index([dueDate])
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
}
